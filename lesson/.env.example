# 后端环境配置模板
# 复制此文件为 .env 并填写实际值

# ===== 必须配置 =====
# JWT 密钥（必须修改为强密钥，建议使用 openssl rand -hex 32 生成）
JWT_SECRET_KEY=your-super-secret-key-change-this

# ===== 可选配置 =====

# CORS 允许的域名（用逗号分隔）
CORS_ORIGINS=http://localhost:3333,https://localhost:3334,http://localhost:14600

# 是否强制 HTTPS（生产环境设为 true）
FORCE_HTTPS=false

# Redis 配置（用于缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
