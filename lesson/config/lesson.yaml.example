# =============================================================================
# B 班级课程配置
# =============================================================================

# 教学通知群 (发送课程相关通知的群)
teach_chatroom: 39175592199@chatroom

# 高考提醒群 (发送高考相关提醒的群)
gk_remind:
 - 57477785315@chatroom

# 教务管理员列表 (可执行课程管理命令)
lesson_admin:
 - yoin007
 - royal1011

# 课程数据存放目录 (Excel 课表等文件) - 跨平台配置
# 根据操作系统自动选择对应路径
lesson_dir:
  Darwin: /Users/yourname/path/to/lesson    # macOS
  Windows: D:/lesson                         # Windows
  Linux: /home/user/lesson                   # Linux

# 周次偏移量 (用于计算当前周次，正数向后，负数向前)
week_change: -8

# 课程管理手册 (添加/删除教师指令说明)
lesson_manul:
 - "添加教师：添加教师（格式：95+\n姓名:\n科目:）"
 - "删除教师：删除教师（格式：95-\n姓名:）"